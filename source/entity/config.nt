import {
  this.entity.option {Follow-Location, option},
}

data config {
| Config(
    host: &string,
    initial-buffer-size: int,
    options: list(option),
  )
}

define default-config(host: &string) -> config {
  Config{
    host,
    initial-buffer-size := 1024,
    options := {
      List[
        Follow-Location(True),
      ]
    },
  }
}
