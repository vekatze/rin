import {
  core.c-string {c-string, to-string},
}

data curl-code {
| Curl-Code(int)
}

data error {
| Curl-Error(error-code: curl-code)
| Curl-Initialization-Error
| Curl-Header-Construction-Error
}

foreign {
  curl_easy_strerror(curl-code) -> pointer,
}

define show-error(e: error) -> string {
  match e {
  | Curl-Error(c) =>
    let str = magic external curl_easy_strerror(c);
    to-string(magic cast(pointer, &c-string, str))
  | Curl-Initialization-Error =>
    *"Failed to initialize libcurl"
  | Curl-Header-Construction-Error =>
    *"Failed to construct the request header"
  }
}
