import {
  core.c-string {c-string, from-string},
  core.string {format},
  http-base.field {Field},
  http-base.header {header},
  this.entity.error {Curl-Header-Construction-Error, error},
  this.rin {rin},
}

data slist {
| _Slist(pointer)
}

foreign {
  curl_slist_append(slist, pointer) -> pointer,
  curl_slist_free_all(slist) -> void,
}

constant _empty-slist: slist {
  magic cast(int, slist, 0)
}

inline _fold-left-maybe<elem-type, result-type>(
  acc: result-type,
  xs: list(elem-type),
  !consumer: (result-type, elem-type) -> ?result-type,
) -> ?result-type {
  let helper =
    define loop(acc: result-type, xs: list(elem-type)) -> ?result-type {
      match xs {
      | Nil =>
        Right(acc)
      | Cons(y, ys) =>
        try tmp = consumer(acc, y);
        loop(tmp, ys)
      }
    };
  helper(acc, xs)
}

define _slist-free(slist-ptr: slist) -> unit {
  let _ = magic external curl_slist_free_all(slist-ptr);
  Unit
}

inline _slist-append-maybe(slist-ptr: slist, key: string, value: string) -> ?slist {
  pin kv = format("{}: {}", List[key, value]);
  pin content = from-string(kv);
  let content = magic cast(&c-string, pointer, content);
  let result = magic external curl_slist_append(slist-ptr, content);
  if eq-int(magic cast(pointer, int, result), 0) {
    _slist-free(slist-ptr);
    none
  } else {
    Right(magic cast(pointer, slist, result))
  }
}

define _make-slist-maybe(fields: header) -> ?slist {
  _fold-left-maybe(_empty-slist, fields, (acc, field) => {
    let Field(key, value) = field;
    _slist-append-maybe(acc, key, value)
  })
}

define _lift-none<a>(e: ?a) -> either(error, a) {
  match e {
  | Right(v) =>
    Right(v)
  | Left(_) =>
    Left(Curl-Header-Construction-Error)
  }
}

define with-header<a>(fields: header, callback: (slist) -> rin(a)) -> rin(a) {
  try slist = _lift-none(_make-slist-maybe(fields));
  let result = callback(slist);
  _slist-free(slist);
  result
}
